<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>同時翻訳マスター v199 Professional</title>
  <style>
    :root { --main-fs: 75px; --sub-fs: 25px; }
    html, body { height: 100%; margin: 0; padding: 0; background: #000; color: #fff; overflow: hidden; font-family: sans-serif; }
    body { display: flex; flex-direction: column; }
    
    .header { background: #1a1a1a; padding: 6px 12px; border-bottom: 2px solid #333; flex-shrink: 0; font-size: 11px; z-index: 100; display: flex; align-items: center; gap: 8px; flex-wrap: nowrap; overflow-x: auto; }
    .group { background: #222; padding: 3px 8px; border-radius: 4px; border: 1px solid #444; display: flex; gap: 6px; align-items: center; white-space: nowrap; }
    input, select { background: #333; color: #fff; border: 1px solid #555; padding: 2px; border-radius: 4px; font-size: 11px; }
    
    #display-area { flex-grow: 1; overflow-y: auto; padding: 20px; display: flex; flex-direction: column; scroll-behavior: smooth; }
    #interim-container { min-height: 160px; margin-bottom: 10px; border-bottom: 2px solid #333; flex-shrink: 0; padding-bottom: 10px; }
    #log-container { display: flex; flex-direction: column; gap: 20px; }

    .orig-text { font-size: var(--sub-fs); color: #888; border-left: 5px solid #444; padding-left: 15px; margin-bottom: 5px; }
    .trans-text { font-weight: 900; line-height: 1.1; word-wrap: break-word; }
    .large-size .trans-text { font-size: var(--main-fs); }
    .large-size .orig-text { font-size: var(--sub-fs); color: #aaa; }

    .log-item:not(:first-child) { opacity: 0.25; filter: blur(0.5px); transition: 0.5s; }
    .log-item:not(:first-child) .trans-text { font-size: 32px; }
    .log-item:not(:first-child) .orig-text { font-size: 18px; }

    .credit { position: fixed; bottom: 12px; right: 20px; font-size: 14px; color: #ffffff; font-weight: bold; z-index: 200; pointer-events: none; text-shadow: 1px 1px 2px #000; }

    #btn-help { background: #444; color: #fff; border: 1px solid #666; padding: 3px 8px; cursor: pointer; border-radius: 4px; }
    #modal-help { display: none; position: fixed; top: 5%; left: 5%; width: 90%; height: 85%; background: #1a1a1a; border: 2px solid #555; padding: 25px; overflow-y: auto; z-index: 300; line-height: 1.6; border-radius: 12px; box-shadow: 0 0 30px rgba(0,0,0,0.5); }
    #modal-help h2 { border-bottom: 2px solid #0066ff; padding-bottom: 10px; }
    #modal-help h3 { color: #0066ff; margin-bottom: 5px; margin-top: 15px; }
    #btn-close-help { background: #cc0000; color: #fff; border: none; padding: 12px; border-radius: 6px; cursor: pointer; font-weight: bold; width: 100%; margin-top: 20px; }

    #vol-meter { width: 40px; height: 10px; background: #333; border-radius: 2px; overflow: hidden; display: inline-block; vertical-align: middle; border: 1px solid #444; }
    #vol-bar { width: 0%; height: 100%; background: #00ff00; transition: width 0.1s; }
  </style>
</head>
<body>

<div class="header">
  <button id="btn-toggle" style="background:#0066ff; color:#fff; border:none; padding:8px 15px; border-radius:8px; font-weight:bold; cursor:pointer;">同時翻訳開始</button>
  <div class="group">音声:<select id="sel-in"></select> 翻訳:<select id="sel-out"></select></div>
  <div class="group">色:<input type="color" id="main-color" value="#ffff00"> 大:<input type="range" id="size-slider" min="40" max="150" value="75" style="width:50px"></div>
  <div class="group">ログ名:<input type="text" id="file-name" placeholder="(空で保存無)" style="width:70px"> 日時:<select id="name-date-pos"><option value="none">無</option><option value="pre" selected>前</option><option value="post">後</option></select></div>
  <div class="group">分割:<input type="number" id="split-sec" value="2.5" step="0.5" style="width:35px">秒 保存:<input type="number" id="auto-save-min" value="10" style="width:35px">分</div>
  <button id="btn-help">説明書</button> 
  <div class="group">
    <div id="vol-meter"><div id="vol-bar"></div></div>
    <span id="status-dot" style="font-size:10px; color:#888;">READY</span>
  </div>
</div>

<div id="display-area">
  <div id="interim-container" class="large-size"></div>
  <div id="log-container"></div>
</div>

<div id="modal-help">
  <h2>📖 同時翻訳マスター 操作説明書</h2>
  <h3>1. 使用手順</h3>
  <ul>
    <li><b>設定の確認</b>: 上部バーで音声と言語を選択します。</li>
    <li><b>開始</b>: <b>「同時翻訳開始」</b>を押しマイクを許可します。</li>
    <li><b>対話</b>: 画面に向かって話すとリアルタイムで字幕が出ます。</li>
    <li><b>終了</b>: <b>「停止」</b>を押すと自動でファイルを保存します。</li>
  </ul>
  <h3>2. 動作環境と安定性</h3>
  <ul>
    <li><b>推奨ブラウザ</b>: <b>Google Chrome</b> / <b>Microsoft Edge</b>。</li>
    <li><b>ネット環境</b>: 安定したWi-Fi環境を推奨します。</li>
    <li><b>API制限</b>: 短時間に大量に話すと翻訳が止まることがあります。一息置いて話すと安定します。</li>
  </ul>
  <h3>3. プライバシーと機密保持</h3>
  <ul>
    <li><b>通信の安全</b>: HTTPS暗号化により通信は保護されています。</li>
    <li><b>データの扱い</b>: 音声はGoogleのサーバーで処理されます。</li>
    <li><b>注意</b>: 極めて重要な個人情報は入力しないでください。</li>
  </ul>
  <h3>4. 困った時の対応策</h3>
  <ul>
    <li><b>翻訳が止まった</b>: 一度「停止」して再開してください。</li>
    <li><b>ウォッチドッグ</b>: 15秒沈黙すると自動で再接続を行います。</li>
    <li><b>音量メーター</b>: マイクが音を拾っているか緑のバーで確認できます。</li>
  </ul>
  <h3>5. データの活用</h3>
  <ul>
    <li><b>Excel連携</b>: ログをコピーしてExcelに貼るだけで綺麗に整列します。</li>
  </ul>
  <button id="btn-close-help">説明書を閉じる</button>
</div>

<div class="credit">Created by フジイヨウスケ with Gemini & ChatGPT</div>

<script>
  const langData = [['日本語','ja-JP','ja'],['英語','en-US','en'],['中国語(簡体)','zh-CN','zh-CN'],['中国語(繁体)','zh-TW','zh-TW'],['中国語(広東)','zh-HK','zh-HK'],['韓国語','ko-KR','ko'],['ベトナム語','vi-VN','vi'],['タイ語','th-TH','th'],['フランス語','fr-FR','fr'],['スペイン語','es-ES','es'],['ドイツ語','de-DE','de'],['ロシア語','ru-RU','ru'],['イタリア語','it-IT','it'],['ポルトガル語','pt-PT','pt'],['インドネシア語','id-ID','id'],['フィリピン語','tl-PH','tl'],['ヒンディー語','hi-IN','hi'],['アラビア語','ar-SA','ar'],['トルコ語','tr-TR','tr'],['ポーランド語','pl-PL','pl'],['オランダ語','nl-NL','nl'],['スウェーデン語','sv-SE','sv'],['ギリシャ語','el-GR','el'],['ペルシャ語','fa-IR','fa'],['マレー語','ms-MY','ms'],['ビルマ語','my-MM','my'],['カンボジア語','km-KH','km'],['ラオス語','lo-LA','lo'],['ウクライナ語','uk-UA','uk'],['モンゴル語','mn-MN','mn']];

  const selIn = document.getElementById('sel-in'), selOut = document.getElementById('sel-out'), btnToggle = document.getElementById('btn-toggle'), logContainer = document.getElementById('log-container'), interimContainer = document.getElementById('interim-container'), mainColor = document.getElementById('main-color'), sizeSlider = document.getElementById('size-slider'), splitSecInput = document.getElementById('split-sec'), autoSaveInput = document.getElementById('auto-save-min'), fileNameInput = document.getElementById('file-name'), nameDatePos = document.getElementById('name-date-pos'), volBar = document.getElementById('vol-bar'), statusDot = document.getElementById('status-dot');

  let isListening = false, recognition, chatLog = [], lastResultTime = 0, autoSaveTimer, healthCheckTimer, currentFullTranscript = "";
  let audioContext, analyser, dataArray, animationId;

  langData.forEach(l => { selIn.innerHTML += `<option value="${l[1]}">${l[0]}</option>`; selOut.innerHTML += `<option value="${l[2]}">${l[0]}</option>`; });

  function updateSize(v) { document.documentElement.style.setProperty('--main-fs', v + 'px'); document.documentElement.style.setProperty('--sub-fs', Math.max(16, v * 0.35) + 'px'); }
  window.addEventListener("load", () => {
    ["fontSize", "fontColor", "langIn", "langOut", "fName", "splitS", "asaveM"].forEach(k => {
      const val = localStorage.getItem(k);
      if(val) {
        if(k === "fontSize") { sizeSlider.value = val; updateSize(val); }
        else if(k === "fontColor") mainColor.value = val;
        else if(k === "langIn") selIn.value = val;
        else if(k === "langOut") selOut.value = val;
        else if(k === "fName") fileNameInput.value = val;
        else if(k === "splitS") splitSecInput.value = val;
        else if(k === "asaveM") autoSaveInput.value = val;
      } else { if(k === "langIn") selIn.value = "ja-JP"; if(k === "langOut") selOut.value = "en-US"; }
    });
  });

  [sizeSlider, mainColor, selIn, selOut, fileNameInput, splitSecInput, autoSaveInput].forEach(el => { el.onchange = () => {
    localStorage.setItem("fontSize", sizeSlider.value); localStorage.setItem("fontColor", mainColor.value);
    localStorage.setItem("langIn", selIn.value); localStorage.setItem("langOut", selOut.value);
    localStorage.setItem("fName", fileNameInput.value); localStorage.setItem("splitS", splitSecInput.value);
    localStorage.setItem("asaveM", autoSaveInput.value);
  };});
  sizeSlider.oninput = () => updateSize(sizeSlider.value);
  document.getElementById('btn-help').onclick = () => document.getElementById('modal-help').style.display = 'block';
  document.getElementById('btn-close-help').onclick = () => document.getElementById('modal-help').style.display = 'none';

  function resetHealthCheck() {
    clearTimeout(healthCheckTimer);
    if (!isListening) return;
    healthCheckTimer = setTimeout(() => { statusDot.textContent = "WATCHDOG"; restartRecognition(); }, 15000); 
  }

  async function startVolumeMeter() {
    if (audioContext) return;
    try {
      const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
      audioContext = new (window.AudioContext || window.webkitAudioContext)();
      analyser = audioContext.createAnalyser();
      const source = audioContext.createMediaStreamSource(stream);
      source.connect(analyser);
      analyser.fftSize = 256;
      dataArray = new Uint8Array(analyser.frequencyBinCount);
      const draw = () => {
        if (!isListening) return;
        analyser.getByteFrequencyData(dataArray);
        let sum = 0; for(let i=0; i<dataArray.length; i++) sum += dataArray[i];
        let volume = Math.min(100, (sum / dataArray.length) * 2.5);
        volBar.style.width = volume + "%";
        volBar.style.background = volume > 70 ? "red" : "#00ff00";
        animationId = requestAnimationFrame(draw);
      };
      draw();
    } catch(e) {}
  }

  function restartRecognition() {
    if (!recognition) return;
    recognition.onend = null;
    recognition.onresult = null;
    recognition.stop();
    setTimeout(() => { if (isListening) initRecognition(); }, 50);
  }

  function initRecognition() {
    const Speech = window.webkitSpeechRecognition || window.SpeechRecognition;
    if (!Speech) return;
    recognition = new Speech();
    recognition.lang = selIn.value;
    recognition.continuous = true;
    recognition.interimResults = true;
    
    recognition.onresult = e => {
      resetHealthCheck();
      statusDot.textContent = "LIVE";
      statusDot.style.color = "red";

      let interimTranscript = "";
      for (let i = 0; i < e.results.length; i++) {
        interimTranscript += e.results[i][0].transcript;
      }

      if (interimTranscript.trim() === "") return;
      currentFullTranscript = interimTranscript.trim(); // 暫定スペースの全内容を常に保持

      const now = Date.now();
      const splitLimit = (parseFloat(splitSecInput.value) || 2.5) * 1000;

      // 修正：時間切れになったら、保持している全内容をコミットしてからリセット
      if (lastResultTime > 0 && (now - lastResultTime > splitLimit)) {
        commitTranslation(currentFullTranscript);
        interimContainer.innerHTML = "";
        lastResultTime = 0;
        currentFullTranscript = "";
        restartRecognition(); 
      } else {
        showInterim(currentFullTranscript);
        lastResultTime = now;
      }
    };

    recognition.onend = () => { if (isListening) setTimeout(initRecognition, 200); };
    recognition.start();
    startVolumeMeter();
    resetHealthCheck();
  }

  async function showInterim(text) {
    if (!text) return;
    const tl = selOut.value;
    let trans = text;
    if (!selIn.value.startsWith(tl)) {
      try {
        const res = await fetch(`https://translate.googleapis.com/translate_a/single?client=gtx&sl=auto&tl=${tl}&dt=t&q=${encodeURIComponent(text)}`);
        const data = await res.json();
        trans = data[0].map(s => s[0]).join("");
      } catch(e) {}
    }
    interimContainer.innerHTML = `<div class="orig-text">... ${text}</div><div class="trans-text" style="color:${mainColor.value}">${trans}</div>`;
  }

  async function commitTranslation(text) {
    if(!text) return;
    const tl = selOut.value;
    let trans = text;
    if (!selIn.value.startsWith(tl)) {
      try {
        const res = await fetch(`https://translate.googleapis.com/translate_a/single?client=gtx&sl=auto&tl=${tl}&dt=t&q=${encodeURIComponent(text)}`);
        const data = await res.json();
        trans = data[0].map(s => s[0]).join("");
      } catch(e) { trans = "[Error]"; }
    }
    const row = document.createElement("div");
    row.className = "log-item large-size";
    row.innerHTML = `<div class="orig-text">${text}</div><div class="trans-text" style="color:${mainColor.value}">${trans}</div>`;
    logContainer.prepend(row);
    chatLog.push(`${getTimestamp()}\t${text}\t${trans}`);
    while (logContainer.children.length > 50) logContainer.lastChild.remove();
  }

  function getTimestamp() {
    const n = new Date();
    const pad = (v) => v.toString().padStart(2, '0');
    return n.getFullYear().toString().slice(-2) + pad(n.getMonth()+1) + pad(n.getDate()) + "_" + pad(n.getHours()) + pad(n.getMinutes()) + pad(n.getSeconds());
  }

  function saveLogFile() {
    if (chatLog.length === 0 || !fileNameInput.value.trim()) return;
    const ts = getTimestamp();
    let fname = fileNameInput.value.trim();
    if(nameDatePos.value === 'pre') fname = ts + "_" + fname;
    if(nameDatePos.value === 'post') fname = fname + "_" + ts;
    const blob = new Blob([chatLog.join("\n")], { type: "text/plain" });
    const a = document.createElement("a"); a.href = URL.createObjectURL(blob); a.download = fname + ".txt"; a.click();
    chatLog = [];
  }

  btnToggle.onclick = () => {
    if (!isListening) {
      isListening = true; chatLog = []; logContainer.innerHTML = ""; interimContainer.innerHTML = "";
      initRecognition();
      btnToggle.textContent = "停止"; btnToggle.style.background = "#cc0000";
      const saveInterval = (parseFloat(autoSaveInput.value) || 10) * 60000;
      autoSaveTimer = setInterval(saveLogFile, saveInterval);
    } else {
      // 停止時に暫定スペースにあるものを最後の一回分としてログに送る
      if (currentFullTranscript) commitTranslation(currentFullTranscript);
      isListening = false; clearInterval(autoSaveTimer); clearTimeout(healthCheckTimer); cancelAnimationFrame(animationId);
      if(audioContext) { audioContext.close(); audioContext = null; }
      if (recognition) { recognition.onend = null; recognition.stop(); }
      saveLogFile();
      statusDot.textContent = "STOPPED";
    }
  };
</script>
</body>
</html>
